# StreamFlow-DataOps — Environment Variables
# Copy to .env and fill in values before running docker compose up

# PostgreSQL (Airflow metadata + crypto staging)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# Airflow
AIRFLOW_WEBSERVER_SECRET_KEY=change_me_to_a_random_secret
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin

# Cassandra
CASSANDRA_USERNAME=cassandra
CASSANDRA_PASSWORD=cassandra

# Grafana
GF_SECURITY_ADMIN_PASSWORD=admin

# Kafka (internal)
KAFKA_BOOTSTRAP_SERVERS=broker:29092
KAFKA_TOPIC=cryptos_created

# Data source
CRYPTO_API_URL=https://api-invest.goonus.io/api/v1/currency?query=&tag=
CRYPTO_TOP_N=11
